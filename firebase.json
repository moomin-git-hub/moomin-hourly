{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "database.rules.json",
      "firestore.rules",
      "**/.*",
      "**/node_modules/**",
      "*.md"
    ],
    "headers": [
      { "source": "/index.html", "headers": [ { "key": "Cache-Control", "value": "no-cache, max-age=0" } ] },
      { "source": "/manifest.json", "headers": [ { "key": "Cache-Control", "value": "no-cache, max-age=0" } ] }
    ],
    "cleanUrls": true
  },
  "database": {
    "rules": "database.rules.json"
  }
}
